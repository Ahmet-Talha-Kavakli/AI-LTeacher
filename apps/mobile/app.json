{
  "expo": {
    "name": "Suno",
    "slug": "suno",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "suno",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.suno.app",
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Suno, AI öğretmenle sesli konuşma derslerinde mikrofonunuzu kullanır.",
        "NSCameraUsageDescription": "Profil fotoğrafı çekmek için kamerayı kullanır.",
        "NSPhotoLibraryUsageDescription": "Profil fotoğrafı seçmek için galeri erişimi gerekir.",
        "NSSpeechRecognitionUsageDescription": "Telaffuzunuzu değerlendirmek için ses tanıma kullanır."
      }
    },
    "android": {
      "package": "com.suno.app",
      "adaptiveIcon": {
        "backgroundColor": "#FF5A5F",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#FFFFFF",
          "dark": {
            "backgroundColor": "#0B0B12"
          }
        }
      ],
      "expo-audio",
      "expo-video",
      "expo-secure-store",
      "expo-asset",
      "expo-localization",
      "expo-apple-authentication",
      "react-native-bottom-tabs"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {}
    }
  }
}

# =============================================================================
# AI Language Teacher — Environment Variables Template
# Copy to .env.local in each app (apps/web, apps/mobile) as needed.
# Never commit real keys.
# =============================================================================

# ---- Supabase ----
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # server-only, never expose to mobile

# ---- AI Providers (server-only, proxied via Vercel API) ----
ANTHROPIC_API_KEY=                  # Claude — text tutor + content generation
AI_GATEWAY_API_KEY=                 # Optional: Vercel AI Gateway
ELEVENLABS_API_KEY=                 # Voice tutor + accent control
MESHY_API_KEY=                      # 3D Pixar-style avatar generation
FAL_API_KEY=                        # Image generation (lesson cards, scenes)
OPENAI_API_KEY=                     # Whisper STT fallback (optional)

# ---- Upstash Redis (leaderboard + rate limits) ----
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ---- RevenueCat (mobile subscriptions) ----
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=
REVENUECAT_SECRET_KEY=              # server webhooks

# ---- Mobile app config ----
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000      # Vercel web app endpoint
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
